{
  "version": "1.0",
  "description": "Joy-Con R to keyboard mapping (macOS)",
  "deadzone": 0.2,
  "poll_interval": 0.01,
  "stick_mode": "4dir",
  "stick_enabled": true,
  "keep_alive_enabled": true,
  "mappings": {
    "buttons": {
      "A": {
        "action": "tap",
        "key": "enter"
      },
      "B": {
        "action": "auto",
        "key": "backspace",
        "long_keys": [
          "cmd",
          "backspace"
        ],
        "repeat": 100
      },
      "X": {
        "action": "tap",
        "key": "escape"
      },
      "Y": {
        "action": "combination",
        "keys": [
          "cmd",
          "tab"
        ]
      },
      "L": {
        "action": "window_switch"
      },
      "ZL": {
        "action": "hold",
        "key": "alt_r"
      },
      "Minus": {
        "action": "combination",
        "keys": [
          "cmd",
          "s"
        ]
      },
      "Capture": {
        "action": "exec",
        "command": [
          "/bin/sh",
          "-c",
          "screencapture ~/Desktop/screenshot-$(date +%Y%m%d-%H%M%S).png"
        ]
      },
      "LStick": {
        "action": "combination",
        "keys": [
          "shift",
          "tab"
        ]
      },
      "SL": {
        "action": "hold",
        "key": "cmd"
      },
      "SR": {
        "action": "window_switch"
      }
    },
    "stick_directions": {
      "up": {
        "action": "auto",
        "key": "up",
        "repeat": 100
      },
      "down": {
        "action": "auto",
        "key": "down",
        "repeat": 100
      },
      "left": {
        "action": "auto",
        "key": "right",
        "repeat": 100
      },
      "right": {
        "action": "auto",
        "key": "left",
        "repeat": 100
      }
    }
  },
  "known_apps": {
    "Ghostty": "Ghostty",
